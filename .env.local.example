# -----------------------------------------------------------------------------
# SajeLabs landing — environment variables
# -----------------------------------------------------------------------------
# Copy to .env.local and fill in real values. Every variable below is OPTIONAL
# at build time — missing values degrade gracefully (no Notion write, no pixel
# fired, no wallet connect project ID). Only the NEXT_PUBLIC_SITE_URL is worth
# setting for correct OG/sitemap URLs in production.
#
# NEVER commit real values to this file. Real values live in .env.local
# (gitignored) for local dev and in Vercel env vars for production.

# Public site URL (used for canonical links, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://sajelabs.com

# --- Notion (durable lead store) ---------------------------------------------
# The application form writes every lead here. This is the only persistence
# layer — set Notion's built-in row notifications on the database to get
# pinged when a lead arrives. Both vars must be set together; missing either
# means no-op (the form returns 202 with a "WhatsApp us directly" message).
# Integration secret from https://www.notion.so/my-integrations
NOTION_API_KEY=
# Database ID — the 32-char hex string between /<workspace>/ and ?v= in the URL
NOTION_LEADS_DATABASE_ID=

# --- Analytics ---------------------------------------------------------------
# Meta Pixel (client)
NEXT_PUBLIC_META_PIXEL_ID=
# Meta Conversions API (server-side — used by /api/apply)
META_CAPI_ACCESS_TOKEN=
# Google Analytics 4 (client)
NEXT_PUBLIC_GA4_ID=

# Meta CAPI Test Events code — set TEMPORARILY to verify CAPI in
# Events Manager → Test Events tab. REMOVE before production conversions count.
META_CAPI_TEST_EVENT_CODE=

# --- Wallet connect / wagmi --------------------------------------------------
# WalletConnect Cloud project ID — https://cloud.reown.com
# Without this the wallet button falls back to injected-only.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Optional: alternate RPC endpoints ---------------------------------------
# Leave blank to use public defaults. Set for production reliability.
NEXT_PUBLIC_ETH_RPC=
NEXT_PUBLIC_ARB_RPC=
NEXT_PUBLIC_BASE_RPC=
